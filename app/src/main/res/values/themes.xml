<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base app theme — Compose handles the actual Material 3 styling. -->
    <style name="Theme.WelcomeBack" parent="android:Theme.Material.NoActionBar">
        <item name="android:statusBarColor">@color/background_dark</item>
        <item name="android:navigationBarColor">@color/background_dark</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="android:windowBackground">@color/background_dark</item>
    </style>

    <!-- Splash screen theme — applied to MainActivity until Compose draws. -->
    <style name="Theme.WelcomeBack.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/background_dark</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_icon</item>
        <item name="postSplashScreenTheme">@style/Theme.WelcomeBack</item>
    </style>
</resources>
